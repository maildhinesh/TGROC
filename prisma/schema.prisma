// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OFFICE_BEARER
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum MembershipType {
  INDIVIDUAL
  FAMILY
  STUDENT_INDIVIDUAL
  STUDENT_FAMILY
}

enum FamilyRelation {
  SPOUSE
  CHILD
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum RsvpStatus {
  YES
  NO
  MAYBE
}

enum PerformanceType {
  SINGING
  DANCE
  SKIT
  POEM_RECITAL
  QUIZ
  STANDUP
}

enum MicType {
  STANDING
  HANDHELD
}

enum EventFeeType {
  FAMILY
  INDIVIDUAL
}

enum MembershipReminderType {
  DAYS_10
  DAYS_5
  DAYS_1
  EXPIRED
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  name            String?
  image           String?
  password        String?
  role              Role           @default(MEMBER)
  status            UserStatus     @default(PENDING)
  membershipType    MembershipType?
  membershipExpiry  DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  accounts             Account[]
  sessions             Session[]
  profile              Profile?
  familyMembers        FamilyMember[]
  contactInfo          ContactInfo?
  notificationSettings NotificationSettings?
  membershipFees       MembershipFee[]
  events               Event[]
  rsvps                EventRsvp[]
  eventPricings            EventPricing[]
  feeReminders             EventFeeReminder[]
  membershipReminders      MembershipExpiryReminder[]

  @@map("users")
}

model MembershipFee {
  id             String         @id @default(cuid())
  membershipType MembershipType
  amount         Decimal        @db.Decimal(10, 2)
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  notes          String?
  createdById    String
  createdAt      DateTime       @default(now())

  createdBy User @relation(fields: [createdById], references: [id])

  @@map("membership_fees")
}

model Event {
  id          String      @id @default(cuid())
  name        String
  description String?     @db.Text
  eventDate   DateTime
  venue       String
  posterUrl   String?
  status      EventStatus @default(DRAFT)
  performanceRegOpen     Boolean   @default(false)
  performanceRegDeadline DateTime?
  createdById String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  createdBy User        @relation(fields: [createdById], references: [id])
  rsvps     EventRsvp[]
  items     EventItem[]
  performances PerformanceRegistration[]
  pricing   EventPricing?
  feeReminders EventFeeReminder[]

  @@map("events")
}

model EventRsvp {
  id         String     @id @default(cuid())
  eventId    String
  userId     String?
  name       String
  email      String
  phone      String?
  attending  RsvpStatus @default(YES)
  adultCount Int        @default(1)
  kidCount   Int        @default(0)
  notes      String?
  createdAt  DateTime   @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  items EventRsvpItem[]

  @@unique([eventId, email])
  @@map("event_rsvps")
}

model EventItem {
  id             String   @id @default(cuid())
  eventId        String
  name           String
  description    String?
  quantityNeeded Int      @default(1)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rsvpItems EventRsvpItem[]

  @@map("event_items")
}

model EventRsvpItem {
  id       String @id @default(cuid())
  rsvpId   String
  itemId   String
  quantity Int    @default(1)

  rsvp EventRsvp @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
  item EventItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([rsvpId, itemId])
  @@map("event_rsvp_items")
}

model PerformanceRegistration {
  id                String          @id @default(cuid())
  eventId           String
  performanceType   PerformanceType
  isGroup           Boolean         @default(false)
  programName       String
  duration          String
  coordinatorName   String
  coordinatorEmail  String
  coordinatorPhone  String
  participantCount  Int?
  songList          String?         @db.Text
  micCount          Int?
  micType           MicType?
  additionalDetails String?         @db.Text
  agreedToTerms     Boolean         @default(false)
  createdAt         DateTime        @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("performance_registrations")
}

model EventPricing {
  id                String        @id @default(cuid())
  eventId           String        @unique
  isFree            Boolean       @default(true)
  feeType           EventFeeType?
  // Family fee tiers
  memberFamilyFee     Decimal?    @db.Decimal(10, 2)
  nonMemberFamilyFee  Decimal?    @db.Decimal(10, 2)
  // Individual fee tiers
  memberAdultFee      Decimal?    @db.Decimal(10, 2)
  nonMemberAdultFee   Decimal?    @db.Decimal(10, 2)
  memberKidFee        Decimal?    @db.Decimal(10, 2)
  nonMemberKidFee     Decimal?    @db.Decimal(10, 2)
  // Student fee tiers
  studentMemberFee    Decimal?    @db.Decimal(10, 2)
  studentNonMemberFee Decimal?    @db.Decimal(10, 2)
  notes             String?       @db.Text
  updatedAt         DateTime      @updatedAt
  updatedById       String

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  updatedBy User  @relation(fields: [updatedById], references: [id])

  @@map("event_pricing")
}

model EventFeeReminder {
  id             String   @id @default(cuid())
  eventId        String
  sentAt         DateTime @default(now())
  sentById       String
  recipientCount Int
  message        String?  @db.Text

  event  Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sentBy User  @relation(fields: [sentById], references: [id])

  @@map("event_fee_reminders")
}

model MembershipExpiryReminder {
  id           String                @id @default(cuid())
  userId       String
  reminderType MembershipReminderType
  expiryDate   DateTime              @db.Date
  sentAt       DateTime              @default(now())
  emailSent    Boolean               @default(false)
  emailError   String?               @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reminderType, expiryDate])
  @@map("membership_expiry_reminders")
}

model Profile {
  id          String    @id @default(cuid())
  userId      String    @unique
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  phone       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model FamilyMember {
  id           String         @id @default(cuid())
  userId       String
  relationship FamilyRelation
  firstName    String
  lastName     String
  dateOfBirth  DateTime?
  email        String?
  phone        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("family_members")
}

model ContactInfo {
  id        String   @id @default(cuid())
  userId    String   @unique
  address   String?
  city      String?
  state     String?
  zipCode   String?
  country   String?  @default("USA")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("contact_info")
}

model NotificationSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  emailNotifications   Boolean  @default(true)
  smsNotifications     Boolean  @default(false)
  newsletterSubscribed Boolean  @default(true)
  eventReminders       Boolean  @default(true)
  membershipAlerts     Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
